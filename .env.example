# =============================================================================
# Media Stack - Environment Configuration
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Edit .env with your actual values
# 3. Never commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# System
# -----------------------------------------------------------------------------

# User/Group IDs for file permissions (Linux/macOS)
# Run `id` in a terminal to find your values. Usually 1000 on first account.
# Windows: keep as 1000 (Docker Desktop handles this via WSL2)
PUID=1000
PGID=1000

# Timezone — full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Log level for services that support it: debug | info | warn | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Storage Paths
# -----------------------------------------------------------------------------
# Use ABSOLUTE paths in production to avoid confusion.
#
# Linux example:
#   CONFIG_DIR=/opt/media-stack/config
#   MEDIA_DIR=/mnt/storage/media
#
# Windows example (use forward slashes):
#   CONFIG_DIR=C:/Users/YourName/media-stack/config
#   MEDIA_DIR=D:/media
#
# The MEDIA_DIR is mounted as /data in containers and expected layout is:
#   /data/movies          -> Radarr root folder
#   /data/tv              -> Sonarr root folder
#   /data/downloads/      -> qBittorrent download directory
#     complete/           -> Completed downloads (Radarr/Sonarr will import from here)
#     incomplete/         -> In-progress downloads

CONFIG_DIR=./config
MEDIA_DIR=./media

# -----------------------------------------------------------------------------
# VPN Configuration (Gluetun)
# Full provider list: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
# Popular providers: mullvad, nordvpn, expressvpn, privateinternetaccess, protonvpn
# -----------------------------------------------------------------------------

# === NordVPN ===
# Gluetun docs: https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/nordvpn.md
VPN_PROVIDER=nordvpn

# ---- Option A: OpenVPN (simplest - no key extraction needed) ----
# Get service credentials (NOT your account password) at:
#   https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/
#
# VPN_TYPE=openvpn
# VPN_USER=<NordVPN service username>
# VPN_PASSWORD=<NordVPN service password>

# ---- Option B: WireGuard / NordLynx (faster, recommended) ------
# Requires extracting your WireGuard private key via the NordVPN CLI.
# See README.md -> NordVPN Setup for step-by-step instructions.
VPN_TYPE=wireguard
# NordVPN: private key only - Gluetun fetches the server list automatically.
# WIREGUARD_ADDRESSES is NOT needed for NordVPN.
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# --- OpenVPN credentials (leave blank when using WireGuard) ---
VPN_USER=
VPN_PASSWORD=

# Server selection - use VPN_COUNTRIES for NordVPN (VPN_REGIONS is not used)
# Examples: VPN_COUNTRIES=Netherlands  or  VPN_COUNTRIES=Switzerland
VPN_REGIONS=
VPN_COUNTRIES=

# -----------------------------------------------------------------------------
# Service Ports
# Change these if any port conflicts with an existing service on your host.
# -----------------------------------------------------------------------------

QBIT_PORT=8080
TORRENTING_PORT=6881
PROWLARR_PORT=9696
RADARR_PORT=7878
SONARR_PORT=8989
JELLYSEERR_PORT=5055
JELLYFIN_PORT=8096
JELLYFIN_HTTPS_PORT=8920
RECOMMENDARR_PORT=3232

# -----------------------------------------------------------------------------
# Jellyfin (optional)
# -----------------------------------------------------------------------------

# Public URL if you expose Jellyfin externally (e.g. https://jellyfin.yourdomain.com)
# JELLYFIN_URL=
